{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run (lldb)",
      "type": "lldb",
      "request": "launch",
      "preLaunchTask": "build active file (g++)",
      "program": "${fileDirname}/${fileBasenameNoExtension}",
      "args": ["bac.in"],
      "cwd": "${fileDirname}",

      // 👇 add these two lines
      "initCommands": ["settings set target.disable-aslr false"],
      "terminal": "integrated"
    }
  ]
}
