{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build active file (g++)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "cd \"${fileDirname}\" && g++ -std=c++20 -g \"${fileBasename}\" -o app && echo \"Built: ${fileDirname}/app\""
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": {
        "owner": "cpp",
        "fileLocation": "absolute",
        "pattern": [
          {
            "regexp": "^(.*):(\\d+):(\\d+):\\s+(fatal error|error|warning|note):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
          }
        ]
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    }
  ]
}
